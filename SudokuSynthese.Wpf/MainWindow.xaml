<Window x:Class="SudokuSynthese.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sudoku Synthèse"
        Height="820"
        Width="1180"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Brush.AppBackground}"
        Focusable="True"
        PreviewKeyDown="Window_PreviewKeyDown">

    <DockPanel>

        <!--
            Barre supérieure de l'application.

            Elle contient le titre, le compteur de temps
            et les actions principales de la partie.
        -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource Brush.TopBar}"
                Padding="14">
            <DockPanel>
                <TextBlock Text="Sudoku Synthèse"
                           Style="{StaticResource TitleTextStyle}"
                           DockPanel.Dock="Left"
                           Margin="0,0,30,0" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <!--
                        Compteur de temps.

                        Il affiche le temps passé sur la grille courante.
                        Le compteur est mis à jour par le MainViewModel.
                    -->
                    <Border Background="{StaticResource Brush.TopBarAlt}"
                            BorderBrush="#374151"
                            BorderThickness="1"
                            CornerRadius="{StaticResource Radius.Chip}"
                            Padding="12,8"
                            Margin="5"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Temps : "
                                       Foreground="#D1D5DB"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />

                            <TextBlock Text="{Binding ElapsedTimeText}"
                                       Foreground="{StaticResource Brush.TextLight}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Button Content="Nouveau"
                            Command="{Binding NewGridCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" />

                    <Button Content="Sauvegarder"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" />

                    <Button Content="Charger"
                            Command="{Binding LoadCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" />

                    <Button Content="Undo"
                            Command="{Binding UndoCommand}"
                            IsEnabled="{Binding CanUndo}"
                            Style="{StaticResource ToolbarButtonStyle}" />

                    <Button Content="Redo"
                            Command="{Binding RedoCommand}"
                            IsEnabled="{Binding CanRedo}"
                            Style="{StaticResource ToolbarButtonStyle}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!--
            Barre de statut.

            Elle affiche les messages informatifs transmis par le ViewModel :
            aide, génération de grille, erreurs ou réussite.
        -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource Brush.SurfaceAlt}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="1,1,0,0"
                Padding="10">
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource MutedTextStyle}" />
        </Border>

        <!--
            Zone principale.

            Elle contient la grille Sudoku à gauche
            et le panneau de contrôle à droite.
        -->
        <Grid Margin="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="330" />
            </Grid.ColumnDefinitions>

            <!--
                Carte de la grille Sudoku.

                Elle affiche les 81 cellules sous forme de grille 9 x 9.
                Chaque cellule est liée à un CellViewModel.
            -->
            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <ItemsControl ItemsSource="{Binding Cells}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="9" Columns="9" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Width="60"
                                    Height="60"
                                    Command="{Binding DataContext.SelectCellCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource SudokuCellButtonStyle}">

                                <Grid>
                                    <!--
                                        Notes en coin.

                                        Les quatre notes affichées correspondent
                                        aux quatre emplacements visuels de la cellule.
                                    -->
                                    <Grid Margin="7"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="{Binding CornerNote1}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.NoteText}"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Top" />

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="2"
                                                   Text="{Binding CornerNote2}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.NoteText}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Top" />

                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="0"
                                                   Text="{Binding CornerNote3}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.NoteText}"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Bottom" />

                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="2"
                                                   Text="{Binding CornerNote4}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.NoteText}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Bottom" />
                                    </Grid>

                                    <!--
                                        Notes centrales.

                                        Elles permettent d'afficher plusieurs candidats
                                        au centre de la cellule sur une ou deux lignes.
                                    -->
                                    <TextBlock Text="{Binding CenterNotesDisplayText}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource Brush.NoteText}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               LineHeight="13"
                                               MaxWidth="52" />

                                    <!--
                                        Valeur principale.

                                        Les chiffres donnés au départ sont affichés en noir.
                                        Les chiffres ajoutés par le joueur sont affichés en bleu.
                                    -->
                                    <TextBlock Text="{Binding ValueText}"
                                               FontSize="30"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.UserValueText}" />

                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGiven}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource Brush.GivenText}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!--
                Panneau latéral.

                Il regroupe les actions du joueur :
                difficulté, mode de saisie, chiffres, couleurs et actions rapides.
            -->
            <Border Grid.Column="1"
                    Style="{StaticResource CardBorderStyle}"
                    Margin="22,0,0,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!--
                            Section de difficulté.

                            Le joueur choisit le niveau souhaité,
                            puis génère une nouvelle grille.
                        -->
                        <TextBlock Text="Niveau de difficulté"
                                   Style="{StaticResource SectionTitleTextStyle}" />

                        <UniformGrid Rows="1" Columns="3">
                            <RadioButton Content="Facile"
                                         GroupName="DifficultyGroup"
                                         IsChecked="{Binding IsEasyDifficultySelected, Mode=OneWay}"
                                         Command="{Binding SetDifficultyCommand}"
                                         CommandParameter="Facile"
                                         Style="{StaticResource SelectableButtonStyle}" />

                            <RadioButton Content="Moyen"
                                         GroupName="DifficultyGroup"
                                         IsChecked="{Binding IsMediumDifficultySelected, Mode=OneWay}"
                                         Command="{Binding SetDifficultyCommand}"
                                         CommandParameter="Moyen"
                                         Style="{StaticResource SelectableButtonStyle}" />

                            <RadioButton Content="Difficile"
                                         GroupName="DifficultyGroup"
                                         IsChecked="{Binding IsHardDifficultySelected, Mode=OneWay}"
                                         Command="{Binding SetDifficultyCommand}"
                                         CommandParameter="Difficile"
                                         Style="{StaticResource SelectableButtonStyle}" />
                        </UniformGrid>

                        <TextBlock Text="{Binding SelectedDifficulty, StringFormat=Niveau actuel : {0}}"
                                   Style="{StaticResource MutedTextStyle}"
                                   Margin="4,4,0,10" />

                        <Button Content="Générer une grille"
                                Command="{Binding NewGridCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" />

                        <Separator Margin="0,18" />

                        <!--
                            Section des modes de saisie.

                            Le mode choisi détermine le comportement
                            d'un chiffre saisi par bouton ou par clavier.
                        -->
                        <TextBlock Text="Modes de saisie"
                                   Style="{StaticResource SectionTitleTextStyle}" />

                        <RadioButton Content="Valeur finale"
                                     GroupName="InputModeGroup"
                                     IsChecked="{Binding IsFinalValueModeSelected, Mode=OneWay}"
                                     Command="{Binding SetModeCommand}"
                                     CommandParameter="FinalValue"
                                     Style="{StaticResource SelectableButtonStyle}" />

                        <RadioButton Content="Note en coin"
                                     GroupName="InputModeGroup"
                                     IsChecked="{Binding IsCornerNoteModeSelected, Mode=OneWay}"
                                     Command="{Binding SetModeCommand}"
                                     CommandParameter="CornerNote"
                                     Style="{StaticResource SelectableButtonStyle}" />

                        <RadioButton Content="Note centrale"
                                     GroupName="InputModeGroup"
                                     IsChecked="{Binding IsCenterNoteModeSelected, Mode=OneWay}"
                                     Command="{Binding SetModeCommand}"
                                     CommandParameter="CenterNote"
                                     Style="{StaticResource SelectableButtonStyle}" />

                        <RadioButton Content="Couleur"
                                     GroupName="InputModeGroup"
                                     IsChecked="{Binding IsColorModeSelected, Mode=OneWay}"
                                     Command="{Binding SetModeCommand}"
                                     CommandParameter="Color"
                                     Style="{StaticResource SelectableButtonStyle}" />

                        <Separator Margin="0,18" />

                        <!--
                            Section des chiffres.

                            Ces boutons permettent de saisir une valeur
                            ou une note dans les cellules sélectionnées.
                        -->
                        <TextBlock Text="Chiffres"
                                   Style="{StaticResource SectionTitleTextStyle}" />

                        <UniformGrid Rows="3" Columns="3">
                            <Button Content="1" Command="{Binding InputNumberCommand}" CommandParameter="1" Style="{StaticResource SideButtonStyle}" />
                            <Button Content="2" Command="{Binding InputNumberCommand}" CommandParameter="2" Style="{StaticResource SideButtonStyle}" />
                            <Button Content="3" Command="{Binding InputNumberCommand}" CommandParameter="3" Style="{StaticResource SideButtonStyle}" />
                            <Button Content="4" Command="{Binding InputNumberCommand}" CommandParameter="4" Style="{StaticResource SideButtonStyle}" />
                            <Button Content="5" Command="{Binding InputNumberCommand}" CommandParameter="5" Style="{StaticResource SideButtonStyle}" />
                            <Button Content="6" Command="{Binding InputNumberCommand}" CommandParameter="6" Style="{StaticResource SideButtonStyle}" />
                            <Button Content="7" Command="{Binding InputNumberCommand}" CommandParameter="7" Style="{StaticResource SideButtonStyle}" />
                            <Button Content="8" Command="{Binding InputNumberCommand}" CommandParameter="8" Style="{StaticResource SideButtonStyle}" />
                            <Button Content="9" Command="{Binding InputNumberCommand}" CommandParameter="9" Style="{StaticResource SideButtonStyle}" />
                        </UniformGrid>

                        <Separator Margin="0,18" />

                        <!--
                            Section des couleurs.

                            Elle permet de choisir la couleur active
                            et de l'appliquer aux cellules sélectionnées.
                        -->
                        <TextBlock Text="Palette de couleurs"
                                   Style="{StaticResource SectionTitleTextStyle}" />

                        <UniformGrid Rows="5" Columns="2">
                            <RadioButton GroupName="ColorGroup"
                                         IsChecked="{Binding IsNoColorSelected, Mode=OneWay}"
                                         Command="{Binding SetColorCommand}"
                                         CommandParameter="None"
                                         Style="{StaticResource ColorPaletteSelectableButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="16"
                                             Height="16"
                                             Fill="{StaticResource Brush.PaletteNone}"
                                             Stroke="{StaticResource Brush.BorderStrong}"
                                             StrokeThickness="1"
                                             Margin="0,0,8,0" />

                                    <TextBlock Text="Aucune"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="ColorGroup"
                                         IsChecked="{Binding IsBlueColorSelected, Mode=OneWay}"
                                         Command="{Binding SetColorCommand}"
                                         CommandParameter="Blue"
                                         Style="{StaticResource ColorPaletteSelectableButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="16"
                                             Height="16"
                                             Fill="{StaticResource Brush.PaletteBlue}"
                                             Stroke="{StaticResource Brush.BorderStrong}"
                                             StrokeThickness="1"
                                             Margin="0,0,8,0" />

                                    <TextBlock Text="Bleu"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="ColorGroup"
                                         IsChecked="{Binding IsGreenColorSelected, Mode=OneWay}"
                                         Command="{Binding SetColorCommand}"
                                         CommandParameter="Green"
                                         Style="{StaticResource ColorPaletteSelectableButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="16"
                                             Height="16"
                                             Fill="{StaticResource Brush.PaletteGreen}"
                                             Stroke="{StaticResource Brush.BorderStrong}"
                                             StrokeThickness="1"
                                             Margin="0,0,8,0" />

                                    <TextBlock Text="Vert"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="ColorGroup"
                                         IsChecked="{Binding IsYellowColorSelected, Mode=OneWay}"
                                         Command="{Binding SetColorCommand}"
                                         CommandParameter="Yellow"
                                         Style="{StaticResource ColorPaletteSelectableButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="16"
                                             Height="16"
                                             Fill="{StaticResource Brush.PaletteYellow}"
                                             Stroke="{StaticResource Brush.BorderStrong}"
                                             StrokeThickness="1"
                                             Margin="0,0,8,0" />

                                    <TextBlock Text="Jaune"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="ColorGroup"
                                         IsChecked="{Binding IsRedColorSelected, Mode=OneWay}"
                                         Command="{Binding SetColorCommand}"
                                         CommandParameter="Red"
                                         Style="{StaticResource ColorPaletteSelectableButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="16"
                                             Height="16"
                                             Fill="{StaticResource Brush.PaletteRed}"
                                             Stroke="{StaticResource Brush.BorderStrong}"
                                             StrokeThickness="1"
                                             Margin="0,0,8,0" />

                                    <TextBlock Text="Rouge"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="ColorGroup"
                                         IsChecked="{Binding IsPurpleColorSelected, Mode=OneWay}"
                                         Command="{Binding SetColorCommand}"
                                         CommandParameter="Purple"
                                         Style="{StaticResource ColorPaletteSelectableButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="16"
                                             Height="16"
                                             Fill="{StaticResource Brush.PalettePurple}"
                                             Stroke="{StaticResource Brush.BorderStrong}"
                                             StrokeThickness="1"
                                             Margin="0,0,8,0" />

                                    <TextBlock Text="Violet"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="ColorGroup"
                                         IsChecked="{Binding IsOrangeColorSelected, Mode=OneWay}"
                                         Command="{Binding SetColorCommand}"
                                         CommandParameter="Orange"
                                         Style="{StaticResource ColorPaletteSelectableButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="16"
                                             Height="16"
                                             Fill="{StaticResource Brush.PaletteOrange}"
                                             Stroke="{StaticResource Brush.BorderStrong}"
                                             StrokeThickness="1"
                                             Margin="0,0,8,0" />

                                    <TextBlock Text="Orange"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="ColorGroup"
                                         IsChecked="{Binding IsPinkColorSelected, Mode=OneWay}"
                                         Command="{Binding SetColorCommand}"
                                         CommandParameter="Pink"
                                         Style="{StaticResource ColorPaletteSelectableButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="16"
                                             Height="16"
                                             Fill="{StaticResource Brush.PalettePink}"
                                             Stroke="{StaticResource Brush.BorderStrong}"
                                             StrokeThickness="1"
                                             Margin="0,0,8,0" />

                                    <TextBlock Text="Rose"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="ColorGroup"
                                         IsChecked="{Binding IsGrayColorSelected, Mode=OneWay}"
                                         Command="{Binding SetColorCommand}"
                                         CommandParameter="Gray"
                                         Style="{StaticResource ColorPaletteSelectableButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="16"
                                             Height="16"
                                             Fill="{StaticResource Brush.PaletteGray}"
                                             Stroke="{StaticResource Brush.BorderStrong}"
                                             StrokeThickness="1"
                                             Margin="0,0,8,0" />

                                    <TextBlock Text="Gris"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="ColorGroup"
                                         IsChecked="{Binding IsCyanColorSelected, Mode=OneWay}"
                                         Command="{Binding SetColorCommand}"
                                         CommandParameter="Cyan"
                                         Style="{StaticResource ColorPaletteSelectableButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="16"
                                             Height="16"
                                             Fill="{StaticResource Brush.PaletteCyan}"
                                             Stroke="{StaticResource Brush.BorderStrong}"
                                             StrokeThickness="1"
                                             Margin="0,0,8,0" />

                                    <TextBlock Text="Cyan"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </RadioButton>
                        </UniformGrid>

                        <Separator Margin="0,18" />

                        <!--
                            Section des actions rapides.

                            Elle expose les commandes d'annulation
                            et de rétablissement de l'historique.
                        -->
                        <TextBlock Text="Actions rapides"
                                   Style="{StaticResource SectionTitleTextStyle}" />

                        <Button Content="Annuler"
                                Command="{Binding UndoCommand}"
                                IsEnabled="{Binding CanUndo}"
                                Style="{StaticResource SideButtonStyle}" />

                        <Button Content="Refaire"
                                Command="{Binding RedoCommand}"
                                IsEnabled="{Binding CanRedo}"
                                Style="{StaticResource SideButtonStyle}" />

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>