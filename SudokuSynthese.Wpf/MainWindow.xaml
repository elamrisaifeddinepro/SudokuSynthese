<Window x:Class="SudokuSynthese.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SudokuSynthese.Wpf.Converters"
        Title="Sudoku Synthèse"
        Height="800"
        Width="1120"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6"
        Focusable="True"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <conv:CellColorToBrushConverter x:Key="CellColorToBrushConverter" />

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SideButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="48"/>
            <Setter Property="MinHeight" Value="40"/>
        </Style>

        <Style x:Key="SudokuCellButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{Binding Color, Converter={StaticResource CellColorToBrushConverter}}"/>
            <Setter Property="BorderBrush" Value="#111827"/>
            <Setter Property="BorderThickness" Value="{Binding BorderThickness}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="CellBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch"/>
                            </Border>

                            <Border x:Name="SelectionBorder"
                                    BorderBrush="#60A5FA"
                                    BorderThickness="{Binding SelectionBorderThickness}"
                                    Margin="0"
                                    Opacity="0"
                                    IsHitTestVisible="False"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CellBorder" Property="Opacity" Value="0.95"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CellBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>

                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="SelectionBorder" Property="Opacity" Value="1"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <DataTrigger Binding="{Binding HasError}" Value="True">
                    <Setter Property="Background" Value="#D95F66"/>
                    <Setter Property="BorderBrush" Value="#B91C1C"/>
                </DataTrigger>

                <DataTrigger Binding="{Binding IsGiven}" Value="True">
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Barre supérieure -->
        <Border DockPanel.Dock="Top"
                Background="#111827"
                Padding="12">
            <DockPanel>
                <TextBlock Text="Sudoku Synthèse"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"
                           Margin="0,0,30,0"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <!-- Compteur de temps -->
                    <Border Background="#1F2937"
                            BorderBrush="#374151"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,8"
                            Margin="5"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Temps : "
                                       Foreground="#D1D5DB"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>

                            <TextBlock Text="{Binding ElapsedTimeText}"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Button Content="Nouveau"
                            Command="{Binding NewGridCommand}"
                            Style="{StaticResource ToolbarButtonStyle}"/>

                    <Button Content="Sauvegarder"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource ToolbarButtonStyle}"/>

                    <Button Content="Charger"
                            Command="{Binding LoadCommand}"
                            Style="{StaticResource ToolbarButtonStyle}"/>

                    <Button Content="Undo"
                            Command="{Binding UndoCommand}"
                            Style="{StaticResource ToolbarButtonStyle}"/>

                    <Button Content="Redo"
                            Command="{Binding RedoCommand}"
                            Style="{StaticResource ToolbarButtonStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Barre inférieure -->
        <Border DockPanel.Dock="Bottom"
                Background="#E5E7EB"
                Padding="10">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="13"
                       Foreground="#374151"/>
        </Border>

        <!-- Zone principale -->
        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="310"/>
            </Grid.ColumnDefinitions>

            <!-- Grille Sudoku -->
            <Border Grid.Column="0"
                    Background="White"
                    Padding="14"
                    CornerRadius="12"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <ItemsControl ItemsSource="{Binding Cells}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="9" Columns="9"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Width="58"
                                    Height="58"
                                    Command="{Binding DataContext.SelectCellCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource SudokuCellButtonStyle}">

                                <Grid>
                                    <!-- Notes en coin -->
                                    <Grid Margin="7"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="{Binding CornerNote1}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="#475569"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Top"/>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="2"
                                                   Text="{Binding CornerNote2}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="#475569"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Top"/>

                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="0"
                                                   Text="{Binding CornerNote3}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="#475569"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Bottom"/>

                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="2"
                                                   Text="{Binding CornerNote4}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="#475569"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Bottom"/>
                                    </Grid>

                                    <!-- Notes centrales -->
                                    <TextBlock Text="{Binding CenterNotesDisplayText}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="#475569"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               LineHeight="13"
                                               MaxWidth="52"/>

                                    <!-- Valeur principale -->
                                    <TextBlock Text="{Binding ValueText}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <!-- Chiffre ajouté par le joueur -->
                                                <Setter Property="Foreground" Value="#1D4ED8"/>

                                                <!-- Chiffre donné au départ -->
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsGiven}" Value="True">
                                                        <Setter Property="Foreground" Value="#111827"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- Panneau latéral -->
            <Border Grid.Column="1"
                    Background="White"
                    Padding="16"
                    CornerRadius="12"
                    BorderBrush="#D1D5DB"
                    BorderThickness="1"
                    Margin="20,0,0,0">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <TextBlock Text="Niveau de difficulté"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <UniformGrid Rows="1" Columns="3">
                            <Button Content="Facile"
                                    Command="{Binding SetDifficultyCommand}"
                                    CommandParameter="Facile"
                                    Style="{StaticResource SideButtonStyle}"/>

                            <Button Content="Moyen"
                                    Command="{Binding SetDifficultyCommand}"
                                    CommandParameter="Moyen"
                                    Style="{StaticResource SideButtonStyle}"/>

                            <Button Content="Difficile"
                                    Command="{Binding SetDifficultyCommand}"
                                    CommandParameter="Difficile"
                                    Style="{StaticResource SideButtonStyle}"/>
                        </UniformGrid>

                        <TextBlock Text="{Binding SelectedDifficulty, StringFormat=Niveau actuel : {0}}"
                                   FontSize="13"
                                   Foreground="#374151"
                                   Margin="4,4,0,10"/>

                        <Button Content="Générer une grille"
                                Command="{Binding NewGridCommand}"
                                Style="{StaticResource SideButtonStyle}"/>

                        <Separator Margin="0,16"/>

                        <TextBlock Text="Modes de saisie"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <Button Content="Valeur finale"
                                Command="{Binding SetModeCommand}"
                                CommandParameter="FinalValue"
                                Style="{StaticResource SideButtonStyle}"/>

                        <Button Content="Note en coin"
                                Command="{Binding SetModeCommand}"
                                CommandParameter="CornerNote"
                                Style="{StaticResource SideButtonStyle}"/>

                        <Button Content="Note centrale"
                                Command="{Binding SetModeCommand}"
                                CommandParameter="CenterNote"
                                Style="{StaticResource SideButtonStyle}"/>

                        <Button Content="Couleur"
                                Command="{Binding SetModeCommand}"
                                CommandParameter="Color"
                                Style="{StaticResource SideButtonStyle}"/>

                        <Separator Margin="0,16"/>

                        <TextBlock Text="Chiffres"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <UniformGrid Rows="3" Columns="3">
                            <Button Content="1" Command="{Binding InputNumberCommand}" CommandParameter="1" Style="{StaticResource SideButtonStyle}"/>
                            <Button Content="2" Command="{Binding InputNumberCommand}" CommandParameter="2" Style="{StaticResource SideButtonStyle}"/>
                            <Button Content="3" Command="{Binding InputNumberCommand}" CommandParameter="3" Style="{StaticResource SideButtonStyle}"/>
                            <Button Content="4" Command="{Binding InputNumberCommand}" CommandParameter="4" Style="{StaticResource SideButtonStyle}"/>
                            <Button Content="5" Command="{Binding InputNumberCommand}" CommandParameter="5" Style="{StaticResource SideButtonStyle}"/>
                            <Button Content="6" Command="{Binding InputNumberCommand}" CommandParameter="6" Style="{StaticResource SideButtonStyle}"/>
                            <Button Content="7" Command="{Binding InputNumberCommand}" CommandParameter="7" Style="{StaticResource SideButtonStyle}"/>
                            <Button Content="8" Command="{Binding InputNumberCommand}" CommandParameter="8" Style="{StaticResource SideButtonStyle}"/>
                            <Button Content="9" Command="{Binding InputNumberCommand}" CommandParameter="9" Style="{StaticResource SideButtonStyle}"/>
                        </UniformGrid>

                        <Separator Margin="0,16"/>

                        <TextBlock Text="Palette de couleurs"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <UniformGrid Rows="5" Columns="2">
                            <Button Content="Aucune" Command="{Binding SetColorCommand}" CommandParameter="None" Style="{StaticResource SideButtonStyle}"/>
                            <Button Content="Bleu" Command="{Binding SetColorCommand}" CommandParameter="Blue" Style="{StaticResource SideButtonStyle}"/>
                            <Button Content="Vert" Command="{Binding SetColorCommand}" CommandParameter="Green" Style="{StaticResource SideButtonStyle}"/>
                            <Button Content="Jaune" Command="{Binding SetColorCommand}" CommandParameter="Yellow" Style="{StaticResource SideButtonStyle}"/>
                            <Button Content="Rouge" Command="{Binding SetColorCommand}" CommandParameter="Red" Style="{StaticResource SideButtonStyle}"/>
                            <Button Content="Violet" Command="{Binding SetColorCommand}" CommandParameter="Purple" Style="{StaticResource SideButtonStyle}"/>
                            <Button Content="Orange" Command="{Binding SetColorCommand}" CommandParameter="Orange" Style="{StaticResource SideButtonStyle}"/>
                            <Button Content="Rose" Command="{Binding SetColorCommand}" CommandParameter="Pink" Style="{StaticResource SideButtonStyle}"/>
                            <Button Content="Gris" Command="{Binding SetColorCommand}" CommandParameter="Gray" Style="{StaticResource SideButtonStyle}"/>
                            <Button Content="Cyan" Command="{Binding SetColorCommand}" CommandParameter="Cyan" Style="{StaticResource SideButtonStyle}"/>
                        </UniformGrid>

                        <Separator Margin="0,16"/>

                        <TextBlock Text="Actions rapides"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <Button Content="Annuler"
                                Command="{Binding UndoCommand}"
                                Style="{StaticResource SideButtonStyle}"/>

                        <Button Content="Refaire"
                                Command="{Binding RedoCommand}"
                                Style="{StaticResource SideButtonStyle}"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>