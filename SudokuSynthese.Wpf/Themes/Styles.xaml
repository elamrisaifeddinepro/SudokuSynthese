<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:SudokuSynthese.Wpf.Converters">

    <!--
        Convertisseur de couleur métier vers Brush WPF.

        Il permet d'afficher les couleurs stockées dans le modèle
        sans introduire de dépendance WPF dans le projet Core.
    -->
    <conv:CellColorToBrushConverter x:Key="CellColorToBrushConverter" />

    <!--
        Rayons standards de l'interface.

        Ces valeurs sont partagées par les cartes, les boutons
        et les éléments visuels de type badge.
    -->
    <CornerRadius x:Key="Radius.Card">14</CornerRadius>
    <CornerRadius x:Key="Radius.Button">8</CornerRadius>
    <CornerRadius x:Key="Radius.Chip">8</CornerRadius>

    <!--
        Espacement standard des cartes.

        Cette ressource assure une marge interne cohérente
        dans les zones principales de l'interface.
    -->
    <Thickness x:Key="Spacing.CardPadding">16</Thickness>

    <!--
        Style du titre principal.

        Utilisé dans la barre supérieure pour afficher
        le nom de l'application.
    -->
    <Style x:Key="TitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextLight}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!--
        Style des titres de section.

        Utilisé dans le panneau latéral pour distinguer
        les groupes d'actions.
    -->
    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.OnSurface}" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <!--
        Style des textes secondaires.

        Utilisé pour les messages d'aide, les statuts
        et les informations moins importantes.
    -->
    <Style x:Key="MutedTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextMuted}" />
    </Style>

    <!--
        Style des cartes principales.

        Utilisé pour la grille Sudoku et le panneau latéral.
    -->
    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Card}" />
        <Setter Property="Padding" Value="{StaticResource Spacing.CardPadding}" />
    </Style>

    <!--
        Style des boutons de la barre supérieure.

        Ces boutons représentent les actions principales :
        nouvelle grille, sauvegarde, chargement, annulation et rétablissement.
    -->
    <Style x:Key="ToolbarButtonStyle" TargetType="Button">
        <Setter Property="Margin" Value="5" />
        <Setter Property="Padding" Value="16,9" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.OnSurface}" />
        <Setter Property="Background" Value="{StaticResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Button}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource Brush.AccentSoft}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource Brush.Accent}" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.TextLight}" />
                        </Trigger>

                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource Brush.AccentStrong}" />
                            <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="2" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Style des boutons du panneau latéral.

        Ce style est utilisé pour les chiffres et les actions rapides.
    -->
    <Style x:Key="SideButtonStyle" TargetType="Button">
        <Setter Property="Margin" Value="4" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.OnSurface}" />
        <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="MinHeight" Value="42" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Button}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource Brush.AccentSoft}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource Brush.Accent}" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.TextLight}" />
                        </Trigger>

                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource Brush.AccentStrong}" />
                            <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="2" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Style des boutons sélectionnables.

        Ce style est utilisé pour les choix exclusifs :
        niveau de difficulté et mode de saisie.
    -->
    <Style x:Key="SelectableButtonStyle" TargetType="RadioButton">
        <Setter Property="Margin" Value="4" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.OnSurface}" />
        <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="MinHeight" Value="42" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Button}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource Brush.AccentSoft}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource Brush.Accent}" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.TextLight}" />
                        </Trigger>

                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource Brush.AccentStrong}" />
                            <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="2" />
                        </Trigger>

                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource Brush.Accent}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource Brush.AccentStrong}" />
                            <Setter Property="Foreground" Value="{StaticResource Brush.TextLight}" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Style du bouton principal du panneau latéral.

        Utilisé pour générer une nouvelle grille à partir
        du niveau de difficulté choisi.
    -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SideButtonStyle}">
        <Setter Property="Background" Value="{StaticResource Brush.Accent}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextLight}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentStrong}" />
    </Style>

    <!--
        Style des boutons sélectionnables de la palette.

        Il permet d'indiquer clairement la couleur active.
    -->
    <Style x:Key="ColorPaletteSelectableButtonStyle" TargetType="RadioButton">
        <Setter Property="Margin" Value="4" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.OnSurface}" />
        <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderStrong}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="MinHeight" Value="40" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Button}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}" />
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource Brush.AccentSoft}" />
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.85" />
                        </Trigger>

                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource Brush.AccentStrong}" />
                            <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="2" />
                        </Trigger>

                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource Brush.AccentStrong}" />
                            <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="3" />
                            <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource Brush.AccentSoft}" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
        Style des cellules de la grille Sudoku.

        Ce style gère l'apparence générale des cellules,
        la sélection, les surbrillances et l'état d'erreur.
    -->
    <Style x:Key="SudokuCellButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{Binding Color, Converter={StaticResource CellColorToBrushConverter}}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.GridLineThick}" />
        <Setter Property="BorderThickness" Value="{Binding BorderThickness}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Cursor" Value="Hand" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="CellBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch" />
                        </Border>

                        <Border x:Name="SelectionBorder"
                                BorderBrush="{StaticResource Brush.Selection}"
                                BorderThickness="{Binding SelectionBorderThickness}"
                                Margin="0"
                                Opacity="0"
                                IsHitTestVisible="False" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CellBorder" Property="Background" Value="{StaticResource Brush.AccentSoft}" />
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="CellBorder" Property="Opacity" Value="0.85" />
                        </Trigger>

                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter TargetName="SelectionBorder" Property="Opacity" Value="1" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <DataTrigger Binding="{Binding IsPeer}" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.PeerHighlight}" />
            </DataTrigger>

            <DataTrigger Binding="{Binding IsSameValue}" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.SameValueHighlight}" />
            </DataTrigger>

            <DataTrigger Binding="{Binding HasError}" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.Error}" />
                <Setter Property="BorderBrush" Value="{StaticResource Brush.ErrorBorder}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>